# Discord Bot トークン（Discord Developer Portal から取得）
DISCORD_TOKEN=your_bot_token_here

# アプリケーション ID（Discord Developer Portal から取得）
CLIENT_ID=your_client_id_here

# スケジュール自動送信先チャンネル ID（チャンネルを右クリック → IDをコピー）
SCHEDULE_CHANNEL_ID=your_schedule_channel_id_here

# Discord Public Key（Discord Developer Portal から取得）
# Interactions Endpoint Webhook の署名検証に使用します。
DISCORD_PUBLIC_KEY=your_public_key_here

# Cron Secret（VercelのCron Jobエンドポイントの簡易認証用）
CRON_SECRET=your_cron_secret
